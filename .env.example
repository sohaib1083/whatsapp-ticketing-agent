# WhatsApp Agent Environment Variables (FREE VERSION!)

# Groq API Configuration (FREE - 30 requests/min, 14,400/day)
# Get your FREE key at: https://console.groq.com/keys
GROQ_API_KEY=

# Python Backend Configuration
PYTHON_BACKEND_URL=http://localhost:5000

# Flask Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# Ticketing System (Optional - or use local JSON storage)
TICKET_SYSTEM_URL=http://localhost:8080/api/tickets
TICKET_SYSTEM_API_KEY=your_ticket_api_key

# Whitelist Configuration
WHITELIST_FILE=config/whitelist.json

# WhatsApp Web Session (stored locally - no API costs!)
WA_SESSION_PATH=.wa_session
